# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use SQLite for dev)
USE_SQLITE=True

# MySQL (only when USE_SQLITE=False)
DB_NAME=skin_scalp_db
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_HOST=localhost
DB_PORT=3306

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440
JWT_ALGORITHM=HS256

# Encryption (sensitive data)
# Generate your own key with: python -c "from core.encryption import generate_key; print(generate_key())"
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# AI models (optional; pipeline has defaults)
MEDIAPIPE_MODEL_PATH=
UNET_MODEL_PATH=

# Optional: XGBoost severity model
XGBOOST_MODEL_PATH=

# Optional: LLM (OpenAI API)
LLM_USE_API=False
OPENAI_API_KEY=your-openai-api-key-if-using-llm
LLM_MODEL_NAME=gpt-3.5-turbo

# XGBoost (optional; empty = fallback used)
XGBOOST_MODEL_PATH=

# LLM (optional)
LLM_USE_API=False
OPENAI_API_KEY=your-key-if-using-api
LLM_MODEL_NAME=gpt-3.5-turbo
