# Backend API base URL (CRA proxies /api → :8000 automatically, so leave blank in dev)
REACT_APP_API_BASE_URL=

# ── Google Maps Places (REQUIRED for the live "Nearby Providers" feature) ──
# Get a key at: https://console.cloud.google.com/
# Steps:
#   1. Create a project, enable billing (Google gives $200/month free credit)
#   2. Enable APIs:  Maps JavaScript API, Places API, Geocoding API
#   3. Credentials → Create credentials → API key
#   4. (Recommended) Restrict the key:
#        - Application restriction: HTTP referrers → http://localhost:3000/*
#        - API restriction: only the 3 APIs above
#   5. Paste the key below and re-run:  npm run build
REACT_APP_GOOGLE_MAPS_API_KEY=
